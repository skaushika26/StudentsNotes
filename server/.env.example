# ── Server ──────────────────────────────────
PORT=5000

# MongoDB connection string
# Local:   mongodb://localhost:27017/notenest
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/notenest
MONGO_URI=mongodb://localhost:27017/notenest

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES=7d

# CORS – URL of your React dev server
CLIENT_URL=http://localhost:3000
